---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ContactCTA from '~/components/ContactCTA.astro';
import Reviews from '~/components/Reviews.astro';
import { Icon } from 'astro-icon/components';
import { business } from '~/data/business';

const values = [
  { icon: 'lucide:wheat',     title: 'Ingrediente atent alese', text: 'Făină, ouă și nuci de calitate, atent selectate pentru fiecare rețetă.' },
  { icon: 'lucide:croissant', title: 'Rețete tradiționale', text: 'Rețete moștenite din generație în generație, perfecționate în patiseria noastră.' },
  { icon: 'lucide:heart',     title: 'Făcut manual',         text: 'Cozonacii și produsele speciale sunt modelate manual, cu pasiune.' },
];
---

<BaseLayout
  title="Despre noi"
  description={`Povestea ${business.name} — patiserie clujeană cu peste 30 de ani de tradiție, rețete moștenite și ingrediente atent alese.`}
  path="/despre"
>
  <section class="mx-auto max-w-4xl px-4 pt-12 md:pt-16 pb-10">
    <h1 class="font-display text-4xl md:text-5xl font-semibold text-brand-900">
      Despre noi
    </h1>
    <p class="mt-3 text-base font-medium text-brand-700 italic">
      {business.slogan}
    </p>
    <div class="mt-6 space-y-5 text-lg text-brand-900/80 leading-relaxed">
      <p>
        Noi suntem <strong>{business.name}</strong> – un brand clujean care, de peste 30 de ani, aduce pe
        mesele voastre gustul autentic al produselor de patiserie făcute cu grijă și pasiune.
      </p>
      <p>
        În fiecare cozonac, ștrudel sau croissant se regăsește tradiția transmisă din generație în generație,
        dar și dorința noastră de a păstra vie bucuria lucrurilor simple. Am crescut alături de clujeni și am
        învățat că cele mai bune gusturi sunt cele care te duc cu gândul acasă.
      </p>
      <p>
        Punem preț pe tihna ardelenească și pe calitate. De aceea, folosim doar ingrediente atent
        selecționate și respectăm procesul autentic de preparare – frământat, modelat și copt cu răbdare.
        Fie că îți este poftă de un cozonac ca în copilărie sau pregătești o comandă pentru un moment
        special, la noi găsești mereu gustul care adună oamenii împreună.
      </p>
      <p class="font-display text-xl text-brand-700">
        {business.name} – din respect pentru voi, din respect pentru calitate.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid gap-6 md:grid-cols-3">
      {values.map((v) => (
        <div class="rounded-2xl bg-white p-6 ring-1 ring-brand-100 shadow-sm">
          <div class="inline-flex size-12 items-center justify-center rounded-xl bg-brand-100 text-brand-700">
            <Icon name={v.icon} class="size-6" />
          </div>
          <h3 class="mt-4 font-display text-xl text-brand-900">{v.title}</h3>
          <p class="mt-2 text-sm text-brand-900/70 leading-relaxed">{v.text}</p>
        </div>
      ))}
    </div>
  </section>

  <Reviews />

  <section class="mx-auto max-w-6xl px-4 py-12">
    <ContactCTA />
  </section>
</BaseLayout>
