---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ProductCard from '~/components/ProductCard.astro';
import ContactCTA from '~/components/ContactCTA.astro';
import { Icon } from 'astro-icon/components';
import { business } from '~/data/business';
import { featuredProducts } from '~/data/products';
---

<BaseLayout
  title="Acasă"
  description={`${business.name} — patiserie și brutărie artizanală în ${business.address.city}. Cozonaci, strudele, croissante, produse pentru înmormântare, parastas și evenimente speciale. Comenzi la ${business.phoneDisplay}.`}
  keywords="cozonaci Cluj, patiserie Cluj, brutarie Cluj, cozonaci artizanali, produse inmormantare Cluj, parastas Cluj, evenimente speciale Cluj, patiserie artizanala Cluj-Napoca"
  path="/"
  includeLocalBusinessSchema={true}
>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="mx-auto max-w-6xl px-4 pt-10 pb-16 md:pt-20 md:pb-24 grid gap-10 md:grid-cols-2 items-center">
      <div>
        <span class="inline-flex items-center gap-2 rounded-full bg-brand-100 px-3 py-1 text-xs font-medium text-brand-700">
          <Icon name="lucide:sparkles" class="size-3.5" />
          Făcut zilnic în Cluj-Napoca
        </span>
        <h1 class="mt-4 font-display text-4xl md:text-6xl font-semibold leading-tight text-brand-900">
          {business.tagline}
        </h1>
        <p class="mt-3 text-base font-medium text-brand-700 italic">
          {business.slogan}
        </p>
        <p class="mt-5 text-lg text-brand-900/70 leading-relaxed max-w-xl">
          {business.shortDescription}
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
         
          <a
            href="/produse"
            class="inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-base font-semibold text-brand-700 ring-1 ring-brand-100 hover:bg-cream-100 transition"
          >
            Vezi produsele
            <Icon name="lucide:arrow-right" class="size-4" />
          </a>
        </div>
      </div>

      <div class="relative" id="cozonac-carousel">
        <div class="aspect-[4/5] rounded-3xl overflow-hidden shadow-xl relative">
          <!-- White background rendered as an image — immune to OS/browser dark mode -->
          <img src="/images/bg-white.svg" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover" alt="" />
          <img src="/images/products/CozonacNuca.png"  alt="Cozonac cu nucă"  class="carousel-slide h-full w-full object-contain absolute inset-0 transition-opacity duration-700 opacity-100" loading="eager" decoding="async" />
          <img src="/images/products/CozonacMac.png"   alt="Cozonac cu mac"   class="carousel-slide h-full w-full object-contain absolute inset-0 transition-opacity duration-700 opacity-0"   loading="eager" decoding="async" />
          <img src="/images/products/CozonacRahat.png" alt="Cozonac cu rahat" class="carousel-slide h-full w-full object-contain absolute inset-0 transition-opacity duration-700 opacity-0"   loading="eager" decoding="async" />
          <img src="/images/products/CozonacCacao.png" alt="Cozonac cu cacao" class="carousel-slide h-full w-full object-contain absolute inset-0 transition-opacity duration-700 opacity-0"   loading="eager" decoding="async" />
        </div>

        <!-- Badge -->
        <div class="absolute -bottom-4 -left-4 rounded-2xl bg-white p-4 shadow-lg ring-1 ring-brand-100 hidden sm:block">
          <div class="flex items-center gap-3">
            <Icon name="lucide:wheat" class="size-8 text-brand-600" />
            <div>
              <div class="font-display text-lg text-brand-900">Cozonacul Ludimi</div>
              <div class="text-xs text-brand-900/60" id="cozonac-type">cu nucă</div>
            </div>
          </div>
        </div>

      </div>

      <script>
        (function () {
          var slides = document.querySelectorAll('#cozonac-carousel .carousel-slide');
          var label  = document.getElementById('cozonac-type');
          var types  = ['cu nucă', 'cu mac', 'cu rahat', 'cu cacao'];
          var current = 0;
          var timer;

          function goTo(index) {
            slides[current].classList.remove('opacity-100');
            slides[current].classList.add('opacity-0');

            current = index;

            slides[current].classList.remove('opacity-0');
            slides[current].classList.add('opacity-100');

            if (label) label.textContent = types[current];
          }

          function next() { goTo((current + 1) % slides.length); }

          timer = setInterval(next, 3500);
        })();
      </script>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="bg-brand-100/40 border-y border-brand-100/60">
    <div class="mx-auto max-w-6xl px-4 py-8 grid gap-6 sm:grid-cols-3 text-center">
      <div class="flex items-center justify-center gap-3">
        <Icon name="lucide:clock" class="size-6 text-brand-600" />
        <span class="text-sm font-medium text-brand-900">Coapte în fiecare dimineață</span>
      </div>
      <div class="flex items-center justify-center gap-3">
        <Icon name="lucide:heart" class="size-6 text-brand-600" />
        <span class="text-sm font-medium text-brand-900">Rețete de familie</span>
      </div>
      <div class="flex items-center justify-center gap-3">
        <Icon name="lucide:map-pin" class="size-6 text-brand-600" />
        <span class="text-sm font-medium text-brand-900">În inima Clujului</span>
      </div>
    </div>
  </section>

  <!-- EVENIMENTE SPECIALE -->
  <section class="mx-auto max-w-6xl px-4 py-16 md:py-20">
    <div class="rounded-3xl bg-brand-50 ring-1 ring-brand-100 p-8 md:p-10">
      <div class="flex items-center gap-3 mb-4">
        <Icon name="lucide:calendar-heart" class="size-6 text-brand-600" />
        <h2 class="font-display text-2xl md:text-3xl font-semibold text-brand-900">Produse pentru ocazii speciale</h2>
      </div>
      <p class="text-brand-900/75 leading-relaxed max-w-2xl">
        Pregătim produse tradiționale pentru <strong>înmormântări, parastase</strong> și orice alt
        <strong>eveniment special</strong>. Comenzile se preiau telefonic, cu timp de pregătire.
      </p>
      <a
        href="/contact"
        class="mt-6 inline-flex items-center gap-2 rounded-full bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 transition"
      >
        <Icon name="lucide:phone" class="size-4" />
        Pentru detalii, contactați-ne
      </a>
    </div>
  </section>

  <!-- FEATURED PRODUCTS -->
  <section class="mx-auto max-w-6xl px-4 py-16 md:py-24">
    <div class="flex items-end justify-between gap-4 mb-10">
      <div>
        <h2 class="font-display text-3xl md:text-4xl font-semibold text-brand-900">
          Cele mai îndrăgite produse
        </h2>
        <p class="mt-2 text-brand-900/70">O selecție din ce coacem în fiecare zi.</p>
      </div>
      <a
        href="/produse"
        class="hidden md:inline-flex items-center gap-1 text-sm font-semibold text-brand-700 hover:text-brand-900"
      >
        Toate produsele <Icon name="lucide:arrow-right" class="size-4" />
      </a>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featuredProducts.map((p) => <ProductCard product={p} />)}
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-4 pb-20">
    <ContactCTA />
  </section>
</BaseLayout>
