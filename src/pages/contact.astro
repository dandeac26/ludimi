---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { business } from '~/data/business';
---

<BaseLayout
  title="Contact"
  description={`Sunați la ${business.phoneDisplay} pentru comenzi. ${business.name} se află pe ${business.address.street}, ${business.address.city}.`}
  path="/contact"
  includeLocalBusinessSchema={true}
>
  <section class="mx-auto max-w-6xl px-4 pt-12 md:pt-16 pb-10">
    <h1 class="font-display text-4xl md:text-5xl font-semibold text-brand-900">
      Contact
    </h1>
    <p class="mt-3 text-lg text-brand-900/70 max-w-2xl">
      Comenzile se preiau exclusiv prin telefon. Vă răspundem cu drag.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-16 grid gap-8 md:grid-cols-2">
    <!-- Contact info -->
    <div class="space-y-6">
      <a
        href={`tel:${business.phone}`}
        class="block rounded-2xl bg-brand-600 p-6 text-white shadow-md hover:bg-brand-700 transition"
      >
        <div class="flex items-center gap-3">
          <Icon name="lucide:phone" class="size-6" />
          <span class="text-sm uppercase tracking-wider opacity-80">Telefon</span>
        </div>
        <div class="mt-2 font-display text-3xl font-semibold">{business.phoneDisplay}</div>
        <div class="mt-1 text-sm opacity-80">Apăsați pentru a suna</div>
      </a>

      <div class="rounded-2xl bg-white p-6 ring-1 ring-brand-100 shadow-sm">
        <div class="flex items-center gap-3 text-brand-700">
          <Icon name="lucide:map-pin" class="size-5" />
          <span class="text-sm uppercase tracking-wider font-medium">Adresă</span>
        </div>
        <div class="mt-2 text-brand-900 leading-relaxed">
          {business.address.street}<br />
          {business.address.postalCode} {business.address.city}, {business.address.region}<br />
          România
        </div>
      </div>

      <div class="rounded-2xl bg-white p-6 ring-1 ring-brand-100 shadow-sm">
        <div class="flex items-center gap-3 text-brand-700">
          <Icon name="lucide:clock" class="size-5" />
          <span class="text-sm uppercase tracking-wider font-medium">Program</span>
        </div>
        <ul class="mt-3 space-y-1 text-brand-900">
          {business.hours.map((h) => (
            <li class="flex justify-between gap-4">
              <span>{h.day}</span>
              <span class="tabular-nums">
                {h.open && h.close ? `${h.open} – ${h.close}` : 'Închis'}
              </span>
            </li>
          ))}
        </ul>
      </div>

      {business.email && (
        <div class="rounded-2xl bg-white p-6 ring-1 ring-brand-100 shadow-sm">
          <div class="flex items-center gap-3 text-brand-700">
            <Icon name="lucide:mail" class="size-5" />
            <span class="text-sm uppercase tracking-wider font-medium">Email</span>
          </div>
          <a href={`mailto:${business.email}`} class="mt-2 block text-brand-900 hover:text-brand-700">
            {business.email}
          </a>
        </div>
      )}
    </div>

    <!-- Map -->
    <div class="rounded-2xl overflow-hidden ring-1 ring-brand-100 shadow-sm bg-cream-100 min-h-[400px]">
      <iframe
        src={business.mapEmbedUrl}
        class="w-full h-full min-h-[400px]"
        style="border:0"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title={`Harta către ${business.name}`}
      ></iframe>
    </div>
  </section>
</BaseLayout>
