---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ProductCard from '~/components/ProductCard.astro';
import ContactCTA from '~/components/ContactCTA.astro';
import { categoryLabels, productsByCategory, type Category } from '~/data/products';
import { business } from '~/data/business';

const groups = productsByCategory();
const categoriesInOrder = (Object.keys(categoryLabels) as Category[])
  .filter((c) => groups[c].length > 0);
---

<BaseLayout
  title="Produse"
  description={`Descoperă produsele noastre: torturi, prăjituri, cozonaci, plăcinte și pâine, făcute zilnic la ${business.name} în ${business.address.city}.`}
  path="/produse"
>
  <section class="mx-auto max-w-6xl px-4 pt-12 md:pt-16 pb-6">
    <h1 class="font-display text-4xl md:text-5xl font-semibold text-brand-900">
      Produsele noastre
    </h1>
    <p class="mt-3 text-lg text-brand-900/70 max-w-2xl">
      Toate produsele se prepară zilnic în patiserie. Pentru comenzi sau întrebări despre disponibilitate,
      vă rugăm să ne sunați la <a href={`tel:${business.phone}`} class="text-brand-700 font-semibold hover:underline">{business.phoneDisplay}</a>.
    </p>
  </section>

  {categoriesInOrder.map((cat) => (
    <section class="mx-auto max-w-6xl px-4 py-10" id={cat}>
      <h2 class="font-display text-2xl md:text-3xl font-semibold text-brand-900 mb-6">
        {categoryLabels[cat]}
      </h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {groups[cat].map((p) => <ProductCard product={p} />)}
      </div>
    </section>
  ))}

  <section class="mx-auto max-w-6xl px-4 py-16">
    <ContactCTA heading="Doriți să comandați?" />
  </section>
</BaseLayout>
