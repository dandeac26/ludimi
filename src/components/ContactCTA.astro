---
import { Icon } from 'astro-icon/components';
import { business } from '~/data/business';

interface Props {
  variant?: 'panel' | 'inline';
  heading?: string;
}
const { variant = 'panel', heading = 'Comenzi prin telefon' } = Astro.props;
---

{variant === 'panel' ? (
  <section class="rounded-3xl bg-brand-600 px-6 py-10 md:px-12 md:py-14 text-center text-white shadow-lg">
    <h2 class="font-display text-3xl md:text-4xl font-semibold">{heading}</h2>
    <p class="mt-3 text-cream-100/90 max-w-xl mx-auto">
      Preluăm comenzile prin telefon, pentru o experiență personală și pentru a putea răspunde fiecărei dorințe.
    </p>
    <a
      href={`tel:${business.phone}`}
      class="mt-6 inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-base font-semibold text-brand-700 shadow hover:bg-cream-50 transition"
    >
      <Icon name="lucide:phone" class="size-5" />
      {business.phoneDisplay}
    </a>
  </section>
) : (
  <a
    href={`tel:${business.phone}`}
    class="inline-flex items-center gap-2 rounded-full bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 transition"
  >
    <Icon name="lucide:phone" class="size-4" />
    Sună acum: {business.phoneDisplay}
  </a>
)}
