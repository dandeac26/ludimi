---
import { Icon } from 'astro-icon/components';
import { business } from '~/data/business';

const nav = [
  { href: '/',        label: 'Acasă' },
  { href: '/produse', label: 'Produse' },
  { href: '/despre',  label: 'Despre noi' },
  { href: '/contact', label: 'Contact' },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="sticky top-0 z-40 border-b border-brand-100/60 bg-cream-50/85 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 md:py-4">
    <a href="/" class="flex items-center gap-2 group">
      <img
        src="/images/products/logo.jpeg"
        alt="Ludimi Patiserie"
        class="size-12 rounded-full object-cover ring-1 ring-brand-200 shadow-sm transition-transform group-hover:scale-105"
      />
      <span class="font-display text-xl md:text-2xl font-semibold text-brand-900">
        {business.name}
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-7">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'text-sm font-medium transition-colors hover:text-brand-700',
            isActive(item.href) ? 'text-brand-700' : 'text-brand-900/70',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href={`tel:${business.phone}`}
      class="hidden md:inline-flex items-center gap-2 rounded-full bg-brand-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 transition"
    >
      <Icon name="lucide:phone" class="size-4" />
      {business.phoneDisplay}
    </a>

    <!-- Mobile: just the phone button (most useful CTA) -->
    <a
      href={`tel:${business.phone}`}
      class="md:hidden inline-flex items-center gap-1.5 rounded-full bg-brand-600 px-3 py-1.5 text-xs font-semibold text-white"
    >
      <Icon name="lucide:phone" class="size-3.5" />
      Sună
    </a>
  </div>

  <!-- Mobile bottom nav -->
  <nav class="md:hidden flex items-center justify-around border-t border-brand-100/60 px-2 py-2 text-[11px] font-medium">
    {nav.map((item) => (
      <a
        href={item.href}
        class:list={[
          'rounded-lg px-3 py-1.5 transition-colors',
          isActive(item.href)
            ? 'bg-brand-100 text-brand-700'
            : 'text-brand-900/70 hover:text-brand-700',
        ]}
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>
