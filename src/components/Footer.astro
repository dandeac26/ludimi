---
import { Icon } from 'astro-icon/components';
import { business } from '~/data/business';

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-brand-100/60 bg-cream-100/50">
  <div class="mx-auto max-w-6xl px-4 py-10 grid gap-8 md:grid-cols-3">

    <div>
      <div class="flex items-center gap-2">
        <Icon name="lucide:croissant" class="size-6 text-brand-600" />
        <span class="font-display text-xl text-brand-900">{business.name}</span>
      </div>
      <p class="mt-3 text-sm text-brand-900/70 leading-relaxed">
        {business.shortDescription}
      </p>
    </div>

    <div>
      <h3 class="text-sm font-semibold text-brand-900">Contact</h3>
      <ul class="mt-3 space-y-2 text-sm text-brand-900/80">
        <li class="flex items-start gap-2">
          <Icon name="lucide:phone" class="size-4 mt-0.5 text-brand-600" />
          <a href={`tel:${business.phone}`} class="hover:text-brand-700">
            {business.phoneDisplay}
          </a>
        </li>
        <li class="flex items-start gap-2">
          <Icon name="lucide:map-pin" class="size-4 mt-0.5 text-brand-600" />
          <span>
            {business.address.street}<br />
            {business.address.postalCode} {business.address.city}
          </span>
        </li>
        {business.email && (
          <li class="flex items-start gap-2">
            <Icon name="lucide:mail" class="size-4 mt-0.5 text-brand-600" />
            <a href={`mailto:${business.email}`} class="hover:text-brand-700">
              {business.email}
            </a>
          </li>
        )}
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold text-brand-900">Program</h3>
      <ul class="mt-3 space-y-1 text-sm text-brand-900/80">
        {business.hours.map((h) => (
          <li class="flex justify-between gap-4">
            <span>{h.day}</span>
            <span class="tabular-nums">
              {h.open && h.close ? `${h.open} – ${h.close}` : 'Închis'}
            </span>
          </li>
        ))}
      </ul>

      {(business.social.facebook || business.social.instagram) && (
        <div class="mt-4 flex gap-3">
          {business.social.facebook && (
            <a href={business.social.facebook} aria-label="Facebook" class="text-brand-600 hover:text-brand-700">
              <Icon name="lucide:facebook" class="size-5" />
            </a>
          )}
          {business.social.instagram && (
            <a href={business.social.instagram} aria-label="Instagram" class="text-brand-600 hover:text-brand-700">
              <Icon name="lucide:instagram" class="size-5" />
            </a>
          )}
        </div>
      )}
    </div>
  </div>

  <div class="border-t border-brand-100/60">
    <div class="mx-auto max-w-6xl px-4 py-4 text-xs text-brand-900/60 flex flex-col sm:flex-row gap-2 justify-between">
      <span>© {year} {business.legalName ?? business.name}. Toate drepturile rezervate.</span>
      <span>Cluj-Napoca, România</span>
    </div>
  </div>
</footer>
